# Application
APP_ENV=local
APP_NAME=billing-v2
APP_HTTP_ADDR=:8080

# Logging
LOG_LEVEL=debug

# PostgreSQL
DB_DSN=postgres://billing:billing@localhost:5432/billing?sslmode=disable

# Security
JWT_SECRET=change-me-local-only
ENCRYPTION_KEY=change-me-32-byte-local-only
AUTH_SESSION_COOKIE_NAME=billing_session
AUTH_SESSION_COOKIE_SECURE=false
AUTH_SESSION_TTL=12h
AUTH_PASSWORD_RESET_TTL=30m

# Optional integrations
METRICS_ENABLED=false
TRACING_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
TELEGRAM_BOT_TOKEN=

# Provider credentials must use sandbox/fake values in local development.
PROVIDER_DEFAULT_MODE=fake

# Cloudmini V3 provider wiring. Leave PROVIDER_DEFAULT_MODE=fake unless an
# approved non-production account, source mapping, quota, and cleanup owner exist.
CLOUDMINI_V3_BASE_URL=
CLOUDMINI_V3_API_TOKEN=
CLOUDMINI_V3_SOURCE_ID=
CLOUDMINI_V3_KIND=
CLOUDMINI_V3_GROUP_ID=
CLOUDMINI_V3_NODE_ID=
CLOUDMINI_V3_PROTOCOL=
CLOUDMINI_V3_BANDWIDTH_LIMIT_MB=0
CLOUDMINI_V3_SPEED_LIMIT_MBPS=0
CLOUDMINI_V3_POLL_INTERVAL=
CLOUDMINI_V3_POLL_TIMEOUT=
