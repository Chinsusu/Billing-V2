# Application
APP_ENV=local
APP_NAME=billing-v2
APP_HTTP_ADDR=:8080

# Logging
LOG_LEVEL=debug

# PostgreSQL
DB_DSN=postgres://billing:billing@localhost:5432/billing?sslmode=disable

# Security
JWT_SECRET=change-me-local-only
ENCRYPTION_KEY=change-me-32-byte-local-only
AUTH_SESSION_COOKIE_NAME=billing_session
AUTH_SESSION_COOKIE_SECURE=false
AUTH_SESSION_TTL=12h

# Optional integrations
METRICS_ENABLED=false
TRACING_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
TELEGRAM_BOT_TOKEN=

# Provider credentials must use sandbox/fake values in local development.
PROVIDER_DEFAULT_MODE=fake
